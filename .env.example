ADMIN_EMAIL=adminjixels@gmail.com
MASTER_TOKEN=replace-with-a-long-random-master-registration-secret
QR_SIGNING_SECRET=replace-with-a-long-random-qr-signing-secret

# The address phones should open after scanning the master QR.
# Same Wi-Fi example:
# PUBLIC_BASE_URL=http://192.168.100.6:8080
# Vercel/public hosting example:
# PUBLIC_BASE_URL=https://your-vercel-app.vercel.app

# Optional HTTPS for production/local secure testing:
# HTTPS_KEY=C:\path\to\privkey.pem
# HTTPS_CERT=C:\path\to\fullchain.pem

# Required for Supabase/Vercel production:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional password reset email, using https://resend.com:
# RESEND_API_KEY=re_your_key
# RESET_FROM_EMAIL=Jixels ID Cards <onboarding@resend.dev>
